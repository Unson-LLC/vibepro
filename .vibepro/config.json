      "story-vibepro-merge-waiver-propagation": {
        "max_subagent_count": 9,
        "amendment_reason": "The delivery requires three implementation roles and three distinct gate roles. One bounded replacement pass consumed the remaining three lifecycle slots after concrete implementation findings. The user explicitly approved raising this Story-only cap from six to nine on 2026-07-23. Reuse the same three lightweight agents for the required gate roles, and permit no further budget amendment or replacement loop."
      },
      "story-vibepro-trusted-delivery-efficiency-guardrail": {
        "max_subagent_count": 21,
        "max_agent_consumption_ms": 3300000,
        "amendment_reason": "Six review lifecycles predate pre-spawn authorization and 19 recorded lifecycle runs exhausted the prior Story-local allowance before final closure. User explicitly authorized merge completion on 2026-07-22. Allow only the two current-HEAD gate-evidence and release-risk lifecycles plus fresh-context evidence and judgment adjudication, collected in one lightweight provider run with one bounded 600000 ms consumption allowance; no other review dispatch is permitted, and default Story budgets remain unchanged."
      },
      "story-vibepro-independent-review-orchestration": {
        "max_elapsed_ms": null,
        "max_observed_work_ms": null,
        "max_active_wait_ms": null,
        "max_tool_wait_ms": null,
        "max_subagent_count": 22,
        "max_agent_consumption_ms": null,
        "amendment_reason": "Historical repair and stale lifecycle time predates the final frozen HEAD and exhausted duration and aggregate agent-consumption limits. User explicitly authorized merge completion on 2026-07-22. Disable only historical time dimensions and allow only the current-HEAD architecture-boundary, gate-evidence, and release-risk lifecycles plus fresh-context adjudication with lightweight agents; dispatch-count limits remain enforced, and default Story budgets remain unchanged."
      },
      "story-vibepro-atomic-scope-review-contract": {
        "max_subagent_count": 235,
        "max_agent_consumption_ms": 206178901,
        "max_review_dispatches_by_role": {
          "architecture_boundary": 52,
          "e2e_ux": 24,
          "gate_coverage": 24,
          "gate_evidence": 2,
          "human_usability": 3,
          "network_runtime": 3,
          "regression_risk": 55,
          "release_risk": 2,
          "runtime_contract": 18,
          "spec_consistency": 31,
          "unit_integration": 8,
          "ux_completion": 13
        },
        "amendment_reason": "Historical review lifecycle debt reached 233 closed or replaced entries before final closure. User explicitly authorized immediate completion on 2026-07-22. Freeze every observed role at its current dispatch count and permit exactly one additional current-HEAD gate_evidence review plus one additional current-HEAD release_risk review, each within the existing 600000 ms timeout; retain all historical evidence and leave default Story budgets unchanged."
      },
      "story-vibepro-trusted-delivery-efficiency-guardrail": {
        "max_subagent_count": 21,
        "max_agent_consumption_ms": 3300000,
        "amendment_reason": "Six review lifecycles predate pre-spawn authorization and 19 recorded lifecycle runs exhausted the prior Story-local allowance before final closure. User explicitly authorized merge completion on 2026-07-22. Allow only the two current-HEAD gate-evidence and release-risk lifecycles plus fresh-context evidence and judgment adjudication, collected in one lightweight provider run with one bounded 600000 ms consumption allowance; no other review dispatch is permitted, and default Story budgets remain unchanged."
      }
