        "responsibility": "vibepro.agent_review.lifecycle",
        "paths": [
          "src/agent-review.js",
          "src/review-repair.js"
        ],
        "symbols": [
          "gate:agent_review",
          "review:preflight",
          "review:record",
          "review:join",
          "parallel_subagent"
        ],
        "risk_surfaces": [
          "review_lifecycle",
          "gate_orchestration"
        ]
      },
      "evidence_requirements": [
        "agent_review_lifecycle_regression"
      ]
    },
    {
      "id": "VIBE-CORE-EV-001",
