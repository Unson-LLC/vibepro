      "applies_to": {
        "responsibility": "vibepro.verification.evidence_lifecycle",
        "paths": [
          "src/verification-evidence.js",
          "src/evidence-reuse.js",
          "src/traceability.js",
          "src/git-fingerprint.js",
          "src/canonical-audit.js"
        ],
        "symbols": [
          "gate:artifact_consistency",
          "verification_evidence",
          "evidence_reuse",
          "binding_status",
          "reused_merge_delta"
        ],
        "risk_surfaces": [
          "verification_evidence",
          "core_workflow_state"
        ]
      },
      "evidence_requirements": [
        "evidence_lifecycle_regression"
      ]
    },
    {
      "id": "VIBE-CORE-STORY-001",
      "statement": "Selected Story source must match changed Story documents and support requirement consistency; Story-local SSOT must not be silently substituted by an unrelated changed Story.",
      "applies_to": {
        "responsibility": "vibepro.story_source.integrity",
        "paths": [
          "src/story-manager.js",
          "src/requirement-consistency.js"
        ],
        "symbols": [
