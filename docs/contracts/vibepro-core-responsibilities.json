{
  "schema_version": "0.1.0",
  "domain": "vibepro-core-responsibilities",
  "clauses": [
    {
      "id": "VIBE-CORE-PR-001",
      "statement": "PR lifecycle execution must use VibePro readiness artifacts as the authority for pr create and execute merge, and must not treat raw GitHub PR state as sufficient without current Gate DAG evidence.",
      "applies_to": {
        "responsibility": "vibepro.pr_lifecycle.execution",
        "paths": [
          "src/merge-manager.js",
          "src/task-manager.js",
          "src/usage-report.js"
        ],
        "symbols": [
          "ready_for_pr_create",
          "pr_create_allowed",
          "execute merge",
          "pr_merge"
        ],
        "risk_surfaces": [
          "gate_orchestration",
          "core_workflow_state"
        ]
      },
      "evidence_requirements": [
        "pr_lifecycle_regression"
      ]
    },
    {
      "id": "VIBE-CORE-AR-001",
      "statement": "Required Agent Review must preserve staged dispatch, parallel subagent provenance, lifecycle closure, and current-head binding before it can satisfy PR-final gates.",
