          "story_source_mismatch",
          "selected_story_id"
        ],
        "risk_surfaces": [
          "gate_orchestration"
        ]
      },
      "evidence_requirements": [
        "story_source_integrity_regression"
      ]
    },
    {
      "id": "VIBE-CORE-JUDGE-001",
      "statement": "Engineering Judgment route and axes must expose risk reasoning without converting weak or unrelated signals into blocking authority or false readiness.",
      "applies_to": {
