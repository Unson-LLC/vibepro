{
  "name": "vibepro",
  "version": "0.1.0-beta.0",
  "description": "Product-intent gates and review evidence for AI coding agents",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unson-LLC/vibepro.git"
  },
  "bugs": {
    "url": "https://github.com/Unson-LLC/vibepro/issues"
  },
  "homepage": "https://github.com/Unson-LLC/vibepro#readme",
  "keywords": [
    "ai-agents",
    "ai-coding",
    "codex",
    "claude-code",
    "developer-tools",
    "pr-gate",
    "pr-review",
    "software-quality",
    "vibe-coding"
  ],
  "bin": {
    "vibepro": "bin/vibepro.js"
  },
  "files": [
    "agent-instructions",
    "bin",
    "src",
    "skills",
    "docs/assets/vibepro-header.png",
    "docs/playbooks",
    "LICENSE",
    "NOTICE",
    "README.md",
    "README.ja.md"
  ],
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:cli": "node scripts/generate-cli-reference.mjs",
    "docs:cli:check": "node scripts/generate-cli-reference.mjs --check",
    "docs:build": "npm run docs:cli:check && node scripts/build-public-manual.mjs && npm run docs:build:check",
    "docs:build:check": "node scripts/check-public-manual-build.mjs",
    "docs:preview": "vitepress preview docs",
    "test": "node --test",
    "typecheck": "node --check bin/vibepro.js && node --check src/*.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "vitepress": "1.6.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
